{
  "manifest_version": 3,
  "name": "Mora Capture",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "tabs", "scripting"],
  "host_permissions": ["http://localhost:5173/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }, "content_scripts": [
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["bridge.js"]
    }
  ]
}
